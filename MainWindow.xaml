<Window x:Class="AfrrCollector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="aFRR Data Collector" Height="760" Width="1200" MinWidth="900" MinHeight="620">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="ResultsRowDefinition" Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="GraphRowDefinition" Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="ComparisonGraphRowDefinition" Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Regions" FontWeight="Bold" Margin="0,0,0,6" />
                    <ListBox x:Name="RegionsListBox" SelectionMode="Multiple" Height="130" />
                </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="From" FontWeight="Bold" Margin="0,0,0,6" />
                    <DatePicker x:Name="FromDatePicker" />
                </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="To" FontWeight="Bold" Margin="0,0,0,6" />
                    <DatePicker x:Name="ToDatePicker" />
                </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Direction" FontWeight="Bold" Margin="0,0,0,6" />
                    <ComboBox x:Name="DirectionComboBox" />
                </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,0">
                    <TextBlock Text="&quot;Rows/day&quot; hint" FontWeight="Bold" Margin="0,0,0,6" />
                    <TextBlock Text="NUCS URL currently uses 100 rows/day." TextWrapping="Wrap" Foreground="#666" />
                </StackPanel>

                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="ExportDatabaseButton" MinWidth="130" Height="32" Margin="0,0,10,0" Content="Export Database" Click="ExportDatabaseButton_OnClick" />
                    <Button Grid.Column="1" x:Name="ImportDatabaseButton" MinWidth="130" Height="32" Margin="0,0,10,0" Content="Import Database" Click="ImportDatabaseButton_OnClick" />
                    <Button Grid.Column="2" x:Name="FetchButton" MinWidth="140" Height="32" Margin="0,0,10,0" Content="Fetch Data" Click="FetchButton_OnClick" />

                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock x:Name="StatusText" Foreground="#666" Text="Ready." />
                        <ProgressBar x:Name="FetchProgressBar" Height="10" Minimum="0" Maximum="100" Value="0" Margin="0,6,0,0" />
                        <TextBlock x:Name="FetchProgressText" Margin="0,4,0,0" Foreground="#666" Text="0%" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Expander Grid.Row="1" Header="Show debug / last error" IsExpanded="False" Margin="0,0,0,10">
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="8">
                <TextBox x:Name="ErrorMessageTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         MinHeight="90" />
            </Border>
        </Expander>

        <Expander Grid.Row="2"
                  Header="Datatable"
                  IsExpanded="True"
                  Margin="0,0,0,10"
                  Expanded="ResultsExpander_OnExpanded"
                  Collapsed="ResultsExpander_OnCollapsed">
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="8">
                <DataGrid x:Name="ResultsDataGrid"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Zone" Binding="{Binding Zone}" Width="110" />
                        <DataGridTextColumn Header="Day" Binding="{Binding Day}" Width="100" />
                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="80" />
                        <DataGridTextColumn Header="Total MW" Binding="{Binding TotalMw, StringFormat=N2}" Width="120" />
                        <DataGridTextColumn Header="Price Min" Binding="{Binding PriceMin, StringFormat=N2}" Width="120" />
                        <DataGridTextColumn Header="Price Max" Binding="{Binding PriceMax, StringFormat=N2}" Width="120" />
                        <DataGridTextColumn Header="Volume" Binding="{Binding Volume, StringFormat=N2}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Expander>

        <GridSplitter Grid.Row="3"
                      Height="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="#DDD"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext" />

        <Expander x:Name="DailyGraphExpander" Grid.Row="4" Header="Graph for Dayly Market Volume" IsExpanded="True" Margin="0,10,0,10" Expanded="GraphExpanders_OnStateChanged" Collapsed="GraphExpanders_OnStateChanged">
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <Button x:Name="ExportGraphButton" Content="Export Graph" MinWidth="120" Height="30" Click="ExportGraphButton_OnClick" />
                    </StackPanel>

                    <oxy:PlotView Grid.Row="1" x:Name="DailyVolumePlot" />
                </Grid>
            </Border>
        </Expander>

        <GridSplitter Grid.Row="5"
                      Height="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="#DDD"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext" />

        <Expander x:Name="ComparisonGraphExpander" Grid.Row="6" Header="Graph for aFRR vs mFRR Max Accepted Bid" IsExpanded="True" Margin="0,10,0,0" Expanded="GraphExpanders_OnStateChanged" Collapsed="GraphExpanders_OnStateChanged">
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                        <TextBlock Text="Compare Region" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="CompareRegionComboBox" Width="90" Margin="0,0,10,0"/>
                        <TextBlock Text="Direction" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="CompareDirectionComboBox" Width="100" Margin="0,0,10,0"/>
                        <Button x:Name="RenderCompareGraphButton" Content="Render aFRR vs mFRR" MinWidth="150" Height="30" Margin="0,0,10,0" Click="RenderCompareGraphButton_OnClick"/>
                        <Button x:Name="ExportCompareGraphButton" Content="Export Graph" MinWidth="120" Height="30" Click="ExportCompareGraphButton_OnClick" />
                    </StackPanel>

                    <oxy:PlotView Grid.Row="1" x:Name="AfrrMfrrComparisonPlot" />
                </Grid>
            </Border>
        </Expander>
    </Grid>
</Window>
